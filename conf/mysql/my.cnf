[client]
port = 3306
socket = /tmp/mysql.sock
default-character-set = utf8mb4

[mysqld]
port = 3306
socket = /tmp/mysql.sock
basedir = /usr/local/mysql
datadir = {{DATA_DIR}}
pid-file = {{DATA_DIR}}/mysql.pid
user = mysql
server-id = 1

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Timezone
default-time-zone = '{{TIMEZONE}}'

# InnoDB — auto-tuned
innodb_buffer_pool_size = {{INNODB_BUFFER_POOL}}
innodb_log_file_size = 256M
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_io_capacity = 200

# Connections — auto-tuned
max_connections = {{MAX_CONNECTIONS}}
max_connect_errors = 100000
wait_timeout = 600
interactive_timeout = 600

# Query cache (disabled in 8.0, kept for MariaDB compat)
# query_cache_type = 0

# Temp tables
tmp_table_size = 64M
max_heap_table_size = 64M

# Logging
log-error = {{DATA_DIR}}/mysql-error.log
slow_query_log = 1
slow_query_log_file = {{DATA_DIR}}/mysql-slow.log
long_query_time = 2

# Binary log (disabled by default to reduce disk I/O)
skip-log-bin

# Security
skip-name-resolve
local-infile = 0

[mysqldump]
quick
max_allowed_packet = 64M
