#!/usr/bin/env bash
# tools/lnmp — Service management command
# Usage: lnmp {start|stop|restart|reload|status|vhost|kill}

SERVICES_LNMP="nginx mysql php-fpm"

get_db_service() {
    if systemctl list-unit-files mariadb.service &>/dev/null && systemctl is-enabled mariadb &>/dev/null; then
        echo "mariadb"
    else
        echo "mysql"
    fi
}

lnmp_start() {
    local db_svc=$(get_db_service)
    for svc in nginx "$db_svc" php-fpm; do
        echo "Starting ${svc}..."
        systemctl start "$svc"
    done
}

lnmp_stop() {
    local db_svc=$(get_db_service)
    for svc in nginx "$db_svc" php-fpm; do
        echo "Stopping ${svc}..."
        systemctl stop "$svc"
    done
}

lnmp_restart() {
    lnmp_stop
    sleep 1
    lnmp_start
}

lnmp_reload() {
    echo "Reloading Nginx..."
    /usr/local/nginx/sbin/nginx -t && systemctl reload nginx
    echo "Reloading PHP-FPM..."
    systemctl reload php-fpm
}

lnmp_status() {
    local db_svc=$(get_db_service)

    echo ""
    echo "┌─────────────────────────────────────────────┐"
    echo "│             LNMP Stack Status                │"
    echo "├──────────────┬──────────┬────────────────────┤"
    echo "│ Service      │ Status   │ Info               │"
    echo "├──────────────┼──────────┼────────────────────┤"

    for svc in nginx "$db_svc" php-fpm redis; do
        local status="stopped"
        local info="-"
        local icon="✗"

        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            status="running"
            icon="✓"
        elif ! systemctl list-unit-files "${svc}.service" &>/dev/null; then
            status="n/a"
            icon="–"
        fi

        # Gather version/info
        case "$svc" in
            nginx)
                [[ -x /usr/local/nginx/sbin/nginx ]] && info=$(/usr/local/nginx/sbin/nginx -v 2>&1 | sed 's|.*/||') || info="-"
                ;;
            mysql|mariadb)
                if [[ "$status" = "running" ]]; then
                    info=$(mysql -u root -e "SELECT VERSION();" -sN 2>/dev/null || echo "-")
                fi
                ;;
            php-fpm)
                [[ -x /usr/local/php/bin/php ]] && info=$(/usr/local/php/bin/php -r 'echo PHP_VERSION;' 2>/dev/null) || info="-"
                ;;
            redis)
                [[ -x /usr/local/redis/bin/redis-server ]] && info=$(/usr/local/redis/bin/redis-server --version 2>/dev/null | awk '{print $3}' | cut -d= -f2) || info="-"
                ;;
        esac

        printf "│ %-12s │ %s %-6s │ %-18s │\n" "$svc" "$icon" "$status" "$info"
    done

    echo "├──────────────┴──────────┴────────────────────┤"
    echo "│ Ports                                        │"
    echo "├──────────────────────────────────────────────┤"

    local found_port=0
    for port in 80 443 3306 6379; do
        local proc
        proc=$(ss -tlnp 2>/dev/null | grep ":${port} " | awk '{print $NF}' | sed 's/.*"\(.*\)".*/\1/' | head -1)
        if [[ -n "$proc" ]]; then
            printf "│  %-6s → %-35s │\n" ":${port}" "$proc"
            found_port=1
        fi
    done
    [[ $found_port -eq 0 ]] && echo "│  (no ports detected)                         │"

    echo "└──────────────────────────────────────────────┘"
    echo ""
}

lnmp_kill() {
    echo "Force killing LNMP processes..."
    killall -9 nginx mysqld php-fpm 2>/dev/null
    echo "Done."
}

# Vhost management — delegate to tools/vhost.sh
lnmp_vhost() {
    local script_dir="$(cd "$(dirname "$0")" && pwd)"
    # Try installed location first, then source tree
    local vhost_sh=""
    for path in "${script_dir}/vhost.sh" /usr/local/lnmp-stack/tools/vhost.sh; do
        [[ -f "$path" ]] && { vhost_sh="$path"; break; }
    done
    [[ -n "$vhost_sh" ]] || { echo "vhost.sh not found"; exit 1; }
    bash "$vhost_sh" "$@"
}

case "${1:-}" in
    start)   lnmp_start ;;
    stop)    lnmp_stop ;;
    restart) lnmp_restart ;;
    reload)  lnmp_reload ;;
    status)  lnmp_status ;;
    kill)    lnmp_kill ;;
    vhost)   shift; lnmp_vhost "$@" ;;
    ssl)     shift; bash "$(dirname "$0")/ssl.sh" "$@" 2>/dev/null || bash /usr/local/lnmp-stack/tools/ssl.sh "$@" ;;
    db)      shift; bash "$(dirname "$0")/db.sh" "$@" 2>/dev/null || bash /usr/local/lnmp-stack/tools/db.sh "$@" ;;
    reset-password) shift; bash "$(dirname "$0")/reset_mysql_password.sh" "$@" 2>/dev/null || bash /usr/local/lnmp-stack/tools/reset_mysql_password.sh "$@" ;;
    *)
        echo "Usage: lnmp {start|stop|restart|reload|status|kill|vhost|ssl|db|reset-password}"
        echo ""
        echo "  start          — Start all LNMP services"
        echo "  stop           — Stop all LNMP services"
        echo "  restart        — Restart all LNMP services"
        echo "  reload         — Reload Nginx and PHP-FPM configs"
        echo "  status         — Show service status"
        echo "  kill           — Force kill all LNMP processes"
        echo "  vhost          — Virtual host management (add|del|list)"
        echo "  ssl            — SSL certificate management (install|renew|revoke|list|self)"
        echo "  db             — Database management (add|del|list|import|export)"
        echo "  reset-password — Reset MySQL root password (from lnmp.conf or interactive)"
        exit 1
        ;;
esac
